{
  "name": "PCIe40 Rust Development Environment",
  "image": "gitlab-registry.cern.ch/mhermoso/pcie40-rs:latest",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined",
    "--privileged"
  ],
  // Configure VS Code settings
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "rust-analyzer.checkOnSave.command": "clippy",
        "editor.formatOnSave": true
      },
    }
  },
}