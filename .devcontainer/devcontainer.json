{
	"name": "Rust PCIe40 Drivers Dev Container",
	"dockerComposeFile": [
		"../docker-compose.yml"
	],
	"service": "rust-dev",
	"workspaceFolder": "/app",
	"customizations": {
		"vscode": {
			"extensions": [
				"rust-lang.rust-analyzer",
				"vadimcn.vscode-lldb",
				"tamasfe.even-better-toml",
				"serayuzgur.crates"
			]
		}
	},
	"remoteUser": "developer"
}